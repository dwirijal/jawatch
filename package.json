{
  "name": "temp_next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/patch-opennext-load-manifest.mjs",
    "dev": "NODE_OPTIONS='--max-old-space-size=4096' next dev",
    "build": "next build",
    "verify": "npm run test:unit && npm run lint && npm run typecheck && npm run build && npm run perf:budgets",
    "perf:budgets": "node scripts/check-route-budgets.mjs",
    "perf:build-and-budgets": "npm run build && npm run perf:budgets",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "link:vercel": "npm exec --yes -- vercel link",
    "deploy:vercel": "npm exec --yes -- vercel --prod",
    "preview:cloudflare": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy:cloudflare": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "lint": "eslint . --max-warnings=0",
    "test:movie": "node scripts/movie-dataflow-check.mjs",
    "test:series": "node scripts/series-dataflow-check.mjs",
    "test:comic": "node scripts/comic-dataflow-check.mjs",
    "test:security": "node scripts/security-check.mjs",
    "test:sources": "node scripts/source-health-check.mjs",
    "test:unit": "node --test tests/unit/*.test.mjs",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@opennextjs/cloudflare": "^1.17.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@vercel/analytics": "^2.0.1",
    "animejs": "^4.3.6",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "next": "16.2.1",
    "postgres": "^3.4.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "redis": "^5.11.0",
    "sanitize-html": "^2.17.2",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.76.0"
  }
}
