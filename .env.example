# API gateway base URL used by server-side data fetches.
DWIZZY_API_BASE_URL=https://api.dwizzy.my.id

# Optional public mirror of the same gateway URL.
NEXT_PUBLIC_DWIZZY_API_BASE_URL=https://api.dwizzy.my.id

# Optional direct PostgreSQL connection for production media reads.
DATABASE_PROVIDER=supabase
SUPABASE_DATABASE_POOL_URL=replace-with-supabase-pool-url
# Fallback if no Supabase-specific URL is set.
DATABASE_URL=replace-with-local-or-hosted-postgres-url
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_REGION=ap-southeast-2
SUPABASE_DB_PASSWORD=your-database-password
SUPABASE_DB_POOL_MODE=supavisor
COMIC_DB_POOL_MAX=1
COMIC_DB_STATEMENT_TIMEOUT_MS=5000
COMIC_DB_CONNECT_TIMEOUT_SECONDS=3
COMIC_DB_IDLE_TIMEOUT_SECONDS=20
COMIC_DB_MAX_LIFETIME_SECONDS=900
COMIC_DB_APPLICATION_NAME=jawatch-web
# Media data source mode:
# - database: this instance reads compact watch/read media directly from Postgres/Supabase
# - gateway: this instance reads compact media from COMIC_API_BASE_URL over HTTP
COMIC_DATA_SOURCE=database
# Optional remote comic origin used when COMIC_DATA_SOURCE=gateway.
COMIC_API_BASE_URL=https://jawatch-origin.example.com
# Shared token for trusted comic-origin forwarding between Vercel and the self-hosted origin.
COMIC_ORIGIN_SHARED_TOKEN=replace-with-a-long-random-secret
# Optional CA bundle for hosted Postgres TLS. Store the full PEM in Vercel env.
# AIVEN_POSTGRES_CA_PEM="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"

# Optional primary Valkey/Redis cache for comics.
VALKEY_URL=replace-with-valkey-rediss-url
AIVEN_VALKEY_URL=replace-with-aiven-valkey-rediss-url
# REDIS_URL=replace-with-redis-rediss-url

# Optional OpenSearch index for canonical title search.
# If omitted, Jawatch falls back to Postgres search-vector/trigram queries.
OPENSEARCH_URL=replace-with-opensearch-url
OPENSEARCH_INDEX_NAME=jawatch-title-search-v1

# Optional Upstash Redis REST cache for comics.
UPSTASH_REDIS_REST_URL=https://us1-example.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# Embedded Supabase Auth (runtime authority for jawatch auth/session).
NEXT_PUBLIC_SUPABASE_URL=https://xyzcompany.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional Supabase analytics sink for comic events.
SUPABASE_URL=https://xyzcompany.supabase.co
SUPABASE_COMIC_ANALYTICS_SCHEMA=public
SUPABASE_COMIC_ANALYTICS_TABLE=comic_analytics_events

# Canonical site URL (metadata, sitemap, robots).
SITE_URL=https://jawatch.web.id

# Optional client origin fallback.
NEXT_PUBLIC_SITE_URL=https://jawatch.web.id

# SFW monetization via Google AdSense.
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-8868090753979495
NEXT_PUBLIC_ADSENSE_SLOT_HORIZONTAL=
NEXT_PUBLIC_ADSENSE_SLOT_VERTICAL=
NEXT_PUBLIC_ADSENSE_SLOT_SQUARE=

# NSFW monetization via ExoClick async zones.
NEXT_PUBLIC_EXOCLICK_ZONE_HORIZONTAL=
NEXT_PUBLIC_EXOCLICK_ZONE_VERTICAL=
NEXT_PUBLIC_EXOCLICK_ZONE_SQUARE=
